# Frontend env. Copy this file to `.env.local` and paste your real values.
# WARNING: every VITE_* value is embedded into the built JavaScript at build
# time and is therefore PUBLIC / extractable from the deployed files. Vite
# embeds them even though `.env.local` is gitignored. Keep these out of source
# control and scope/rotate them accordingly.

# --- GitHub cloud sync ---------------------------------------------------
# There is NO sync-token env var. The GitHub token is entered inside the app
# (Header -> Connect) and stored only in the browser's localStorage, so it is
# never embedded in the bundle (which is what got earlier tokens auto-revoked).

# --- Telegram visit notification (optional) ------------------------------
# Set VITE_ENABLE_VISIT_NOTIFY=false to disable the ping entirely.
# If the bot is abused, rotate the token in BotFather.
VITE_ENABLE_VISIT_NOTIFY=true
VITE_TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
VITE_TELEGRAM_CHAT_ID=PASTE_TELEGRAM_CHAT_ID_HERE
