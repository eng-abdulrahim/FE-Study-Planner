# Telegram visit notification (frontend-only, optional).
#
# Copy this file to `.env.production` (used by `npm run build`) and paste your
# real values. WARNING: these values are embedded into the built JavaScript at
# build time and are therefore PUBLIC / extractable from the deployed files.
# Vite embeds them even if `.env.production` is gitignored. If the bot is abused,
# rotate the token in BotFather.
#
# Set VITE_ENABLE_VISIT_NOTIFY=false to disable the ping entirely.

VITE_ENABLE_VISIT_NOTIFY=true
VITE_TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
VITE_TELEGRAM_CHAT_ID=PASTE_TELEGRAM_CHAT_ID_HERE
